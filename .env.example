# ════════════════════════════════════════════════════════════════════════════════
# AI-VANTAGE — Environment Variables
# Copy this file to .env.local and fill in your keys.
# The app works out of the box via RSS + GDELT + Google News RSS (no keys needed).
# Add API keys one by one to unlock more sources and better AI quality.
# ════════════════════════════════════════════════════════════════════════════════


# ── ZERO-KEY SOURCES (always active, no sign-up needed) ─────────────────────
# • RSS Feeds        — 30+ outlets: BBC, Reuters, AP, Al Jazeera, TechCrunch, Wired…
# • GDELT            — https://gdeltproject.org (global event database, no key)
# • Google News RSS  — news.google.com/rss/search (free, no key, runs on every search)
#
# These three sources alone cover most queries. API keys add breadth and depth.


# ── FREE API SOURCES (register once, free tier) ──────────────────────────────

# GNews — https://gnews.io
# Free: 100 req/day · Sign up → gnews.io/register
GNEWS_API_KEY=

# NewsAPI — https://newsapi.org
# Free: 100 req/day (dev plan, localhost only) · Sign up → newsapi.org/register
NEWS_API_KEY=

# The Guardian Open Platform — https://open-platform.theguardian.com
# Free: 5,000 req/day · Register → open-platform.theguardian.com/access/
GUARDIAN_API_KEY=

# New York Times — https://developer.nytimes.com
# Free: 500 req/day, 5 req/min · Register → developer.nytimes.com/accounts/create
NYT_API_KEY=

# Currents API — https://currentsapi.services
# Free: 600 req/day · Register → currentsapi.services/en/register
CURRENTS_API_KEY=

# NewsData.io — https://newsdata.io
# Free: 200 credits/day · Register → newsdata.io/register
NEWSDATA_API_KEY=

# Mediastack — https://mediastack.com
# Free: 500 req/month · Register → mediastack.com/signup/free
# Note: free plan uses HTTP (not HTTPS)
MEDIASTACK_API_KEY=

# World News API — https://worldnewsapi.com
# Free: 100 req/day · Register → worldnewsapi.com/pricing
WORLDNEWS_API_KEY=

# Perigon — https://www.goperigon.com
# Free: 100 req/day · Register → goperigon.com/pricing
PERIGON_API_KEY=


# ── Google Custom Search (broader web results, optional) ─────────────────────
# Free tier: 100 queries/day
# Step 1 — Get API key: console.cloud.google.com → Enable "Custom Search API"
# Step 2 — Create a Search Engine: programmablesearchengine.google.com → get CX ID
#           Set it to search the entire web: Settings → Search the entire web
GOOGLE_API_KEY=
GOOGLE_CSE_ID=


# ── AI PROVIDERS ──────────────────────────────────────────────────────────────
#
# Used for THREE features:
#   1. Query optimizer  — refines raw user input into clean API keywords
#   2. Article ranker   — picks & orders the 12 most relevant from up to 25 candidates
#   3. Report generator — produces Digest, Editorial, and Q&A from selected articles
#
# Priority order: Groq → OpenRouter → Gemini → Anthropic
# You only need ONE provider configured.
#
# Smart fallback: if a model hits a rate limit (429), the app automatically tries
# the next model on the same key, then the next key, then the next provider.
# Error is shown only when every key × model × provider is exhausted.
#
# ── Groq — https://console.groq.com (free tier, fastest) ────────────────────
# Add up to 10 keys — requests are distributed randomly to spread quota.
# Fallback model order (auto): llama-3.1-8b-instant → llama-3.2-3b → llama-3.2-1b
#   → gemma2-9b-it → llama3-8b-8192 → llama-3.3-70b-versatile → mixtral-8x7b
GROQ_API_KEY=
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
GROQ_API_KEY_7=
GROQ_API_KEY_8=
GROQ_API_KEY_9=
GROQ_API_KEY_10=
# Override preferred model (still falls back to others on rate limit):
# GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenRouter — https://openrouter.ai (free models available) ───────────────
# Add up to 5 keys for rotation.
# Fallback model order (auto): llama-3.1-8b:free → gemma-2-9b:free → phi-3-mini:free
#   → mistral-7b:free → llama-3.2-3b:free → qwen-2-7b:free → gemma-2-2b:free
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_API_KEY_4=
OPENROUTER_API_KEY_5=
# Override preferred model:
# OPENROUTER_MODEL=google/gemma-2-9b-it:free

# ── Google Gemini — https://aistudio.google.com (free tier) ─────────────────
# Add up to 4 keys for rotation.
# Fallback model order (auto): gemini-1.5-flash → gemini-1.5-flash-8b
#   → gemini-2.0-flash-lite → gemini-2.0-flash → gemini-1.5-pro → gemini-1.0-pro
GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
# Override preferred model:
# GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic Claude — https://console.anthropic.com ────────────────────────
# Fallback model order (auto): claude-haiku-4-5 → claude-haiku-3-5 → claude-3-haiku
ANTHROPIC_API_KEY=


# ── Virlo Platform Key (Trending Hashtags section) ───────────────────────────
# Powers the real-time social trending section on the landing page.
# Get it from api.virlo.io → Dashboard → API Keys
VIRLO_API_KEY=


# ── Supabase (REQUIRED for deployment) ───────────────────────────────────────
# 1. Create a free project at supabase.com
# 2. Run supabase/schema.sql in the SQL Editor
# 3. Copy these values from: Project → Settings → API
#
# Project URL (e.g. https://xyzxyzxyz.supabase.co)
SUPABASE_URL=
# service_role key — keep this secret, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=


# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
